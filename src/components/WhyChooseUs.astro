---
// WhyChooseUs section – outcome-first cards
import { Image } from 'astro:assets';
import websiteImg from '@/assets/images/why-choose-us/website.webp';
import googleImg from '@/assets/images/why-choose-us/google.webp';
import supportImg from '@/assets/images/why-choose-us/support.png';
---

<section class="relative py-16 sm:py-20 md:py-24 px-4 sm:px-6 lg:px-8 bg-bg overflow-hidden">
	<div class="relative max-w-4xl mx-auto">
		<!-- Section header -->
		<div class="text-center mb-10 sm:mb-12">
			<p class="font-body text-section-tiny font-medium text-textMuted mb-3">
				Why choose us
			</p>
			<h2 class="font-headline text-section-header font-medium text-text mb-1">
				Built for results, not just looks
			</h2>
			<p class="font-body text-section-subheading font-medium text-textMuted max-w-md mx-auto">
				We build websites that don't just look good, they drive results. Here's what you get when you work with Bluebird.
			</p>
		</div>

		<!-- 2x2 grid - outcome-first cards -->
		<div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5 max-w-3xl mx-auto">
			<!-- Look credible online -->
			<div class="flex flex-col overflow-hidden rounded-xl bg-white border border-accent/10 shadow-md hover:shadow-lg hover:border-accent/20 transition-all duration-300">
				<div class="w-full aspect-[4/3] overflow-hidden rounded-t-xl bg-gray-50">
					<Image src={websiteImg} alt="Lighthouse performance report" width={800} height={600} class="w-full h-full object-cover object-center" loading="lazy" />
				</div>
				<div class="p-4 sm:p-5 flex-1 flex flex-col">
					<h3 class="font-body text-section-inner-title font-medium text-text mb-1.5">Look credible online</h3>
					<p class="font-body text-section-body font-medium text-textMuted leading-relaxed">
						Professional design, clear structure, and fast load times so your business feels trustworthy from the first click.
					</p>
				</div>
			</div>

			<!-- Turn visits into inquiries -->
			<div class="flex flex-col overflow-hidden rounded-xl bg-white border border-accent/10 shadow-md hover:shadow-lg hover:border-accent/20 transition-all duration-300">
				<div class="w-full aspect-[4/3] overflow-hidden rounded-t-xl bg-accentSubtle/20 flex flex-col items-center justify-center p-6">
					<div class="space-y-3 w-full max-w-xs">
						<div class="flex items-center gap-3">
							<div class="w-8 h-8 rounded-full bg-accent/15 flex items-center justify-center flex-shrink-0">
								<svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
							</div>
							<span class="text-sm font-medium text-text">Clear calls-to-action</span>
						</div>
						<div class="flex items-center gap-3">
							<div class="w-8 h-8 rounded-full bg-accent/15 flex items-center justify-center flex-shrink-0">
								<svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
							</div>
							<span class="text-sm font-medium text-text">Contact forms that work</span>
						</div>
						<div class="flex items-center gap-3">
							<div class="w-8 h-8 rounded-full bg-accent/15 flex items-center justify-center flex-shrink-0">
								<svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
							</div>
							<span class="text-sm font-medium text-text">Conversion-focused layout</span>
						</div>
					</div>
				</div>
				<div class="p-4 sm:p-5 flex-1 flex flex-col">
					<h3 class="font-body text-section-inner-title font-medium text-text mb-1.5">Turn visits into inquiries</h3>
					<p class="font-body text-section-body font-medium text-textMuted leading-relaxed">
						Intentional layouts and strong CTAs so visitors know what to do next, and actually get in touch.
					</p>
				</div>
			</div>

			<!-- Show up better on Google -->
			<div class="flex flex-col overflow-hidden rounded-xl bg-white border border-accent/10 shadow-md hover:shadow-lg hover:border-accent/20 transition-all duration-300">
				<div class="w-full aspect-[4/3] overflow-hidden rounded-t-xl bg-gray-50">
					<Image src={googleImg} alt="SEO and accessibility" class="w-full h-full object-cover object-center" loading="lazy" />
				</div>
				<div class="p-4 sm:p-5 flex-1 flex flex-col">
					<h3 class="font-body text-section-inner-title font-medium text-text mb-1.5">Show up better on Google</h3>
					<p class="font-body text-section-body font-medium text-textMuted leading-relaxed mb-3">
						On-page SEO, fast performance, and solid structure so search engines can find you. Add Local SEO when you're ready to get found by more local customers.
					</p>
					<div class="space-y-1.5">
						<div class="flex items-center gap-2">
							<div class="w-4 h-4 rounded-full bg-accentSubtle flex items-center justify-center flex-shrink-0">
								<svg class="w-2.5 h-2.5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
							</div>
							<span class="text-[10px] text-textMuted">Meta tags & structured data</span>
						</div>
						<div class="flex items-center gap-2">
							<div class="w-4 h-4 rounded-full bg-accentSubtle flex items-center justify-center flex-shrink-0">
								<svg class="w-2.5 h-2.5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
							</div>
							<span class="text-[10px] text-textMuted">Mobile-friendly & fast</span>
						</div>
						<div class="flex items-center gap-2">
							<div class="w-4 h-4 rounded-full bg-accentSubtle flex items-center justify-center flex-shrink-0">
								<svg class="w-2.5 h-2.5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
							</div>
							<span class="text-[10px] text-textMuted">Local SEO add-on available</span>
						</div>
					</div>
				</div>
			</div>

			<!-- Stop chasing website fixes -->
			<div class="flex flex-col overflow-hidden rounded-xl bg-white border border-accent/10 shadow-md hover:shadow-lg hover:border-accent/20 transition-all duration-300">
				<div class="w-full aspect-[4/3] overflow-hidden rounded-t-xl bg-gray-50">
					<Image src={supportImg} alt="Ongoing support and maintenance" width={800} height={600} class="w-full h-full object-cover object-center" loading="lazy" />
				</div>
				<div class="p-4 sm:p-5 flex-1 flex flex-col">
					<h3 class="font-body text-section-inner-title font-medium text-text mb-1.5">Stop chasing website fixes</h3>
					<p class="font-body text-section-body font-medium text-textMuted leading-relaxed">
						Care Plan covers hosting, monitoring, and minor updates. Lean setup, ongoing support, so you can focus on your business.
					</p>
				</div>
			</div>
		</div>
	</div>
</section>
