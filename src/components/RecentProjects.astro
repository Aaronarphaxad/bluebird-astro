---
import { Image } from 'astro:assets';
import projectsData from '../content/projects.json';
import axiomzurichImg from '@/assets/images/featured-projects/axiomzurich.webp';
import advancedapsImg from '@/assets/images/featured-projects/advancedaps.webp';
import elimunowwImg from '@/assets/images/featured-projects/elimunoww.webp';
import neyneyskitchenImg from '@/assets/images/featured-projects/neyneyskitchen.webp';
import mwsGarageDoorImg from '@/assets/images/featured-projects/mws-garage-door.webp';

const projectImageMap: Record<string, typeof axiomzurichImg> = {
	'axiom-zurich': axiomzurichImg,
	'advancedaps': advancedapsImg,
	'elimu-international': elimunowwImg,
	'ney-neys-kitchen': neyneyskitchenImg,
	'jason-garage-doors': mwsGarageDoorImg,
};
---

<section class="projects-section relative py-16 sm:py-20 md:py-24 bg-bg" aria-label="Featured projects">
	<div class="max-w-6xl mx-auto px-4 sm:px-6 md:px-12">
		<div class="text-center mb-10 sm:mb-12">
			<p class="font-body text-section-tiny font-medium text-textMuted mb-3">
				Featured projects
			</p>
			<h2 class="font-headline text-section-header font-medium text-text mb-1">
				Recent work we're proud of
			</h2>
			<p class="font-body text-section-subheading font-medium text-textMuted max-w-md mx-auto">
				Fast, conversion-focused websites and web applications.
			</p>
		</div>

		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
			{projectsData.map((project, index) => {
				const img = projectImageMap[project.id];
				const href = project.viewUrl ?? '#';
				const isExternal = href.startsWith('http');
				return (
					<article class="group">
						<a
							href={href}
							target={isExternal ? '_blank' : undefined}
							rel={isExternal ? 'noopener noreferrer' : undefined}
							class="block h-full rounded-2xl bg-white border border-black/5 shadow-[0_1px_0_rgba(0,0,0,0.04)] hover:shadow-[0_20px_40px_-12px_rgba(0,0,0,0.12)] hover:border-black/8 transition-all duration-300 overflow-hidden focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
							aria-label={`View ${project.title}`}
						>
							{img ? (
								<div class="aspect-video overflow-hidden bg-black/[0.03]">
									<Image
										src={img}
										alt=""
										width={800}
										height={450}
										class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]"
										loading={index < 3 ? 'eager' : 'lazy'}
									/>
								</div>
							) : null}
							<div class="p-5 sm:p-6">
								<h3 class="font-headline text-lg sm:text-xl font-semibold text-text mb-2 group-hover:text-accent transition-colors">
									{project.title}
								</h3>
								{project.summary ? (
									<p class="text-sm text-textMuted leading-relaxed line-clamp-2 mb-3">
										{project.summary}
									</p>
								) : null}
								{project.tags?.length ? (
									<ul class="flex flex-wrap gap-2" aria-label="Project tags">
										{project.tags.map((tag) => (
											<li class="inline-flex items-center px-2.5 py-1 rounded-full bg-black/5 text-text text-xs font-medium">
												{tag}
											</li>
										))}
									</ul>
								) : null}
								<span class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-accent group-hover:gap-3 transition-all">
									View project
									<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
									</svg>
								</span>
							</div>
						</a>
					</article>
				);
			})}
		</div>

		<div class="mt-10 sm:mt-12 text-center">
			<a
				href="/projects"
				class="inline-flex items-center gap-2 rounded-full bg-text text-bg px-5 py-2.5 text-sm font-medium hover:bg-text/90 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
			>
				View all projects
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
				</svg>
			</a>
		</div>
	</div>
</section>
