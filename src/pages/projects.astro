---
import { Image as AstroImage } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import projectsData from '../content/projects.json';
import projectsPageContent from '../content/pages/projects.json';
import axiomzurichImg from '../assets/images/featured-projects/axiomzurich.webp';
import advancedapsImg from '../assets/images/featured-projects/advancedaps.webp';
import elimunowwImg from '../assets/images/featured-projects/elimunoww.webp';
import neyneyskitchenImg from '../assets/images/featured-projects/neyneyskitchen.webp';
import mwsGarageDoorImg from '../assets/images/featured-projects/mws-garage-door.webp';

const { meta, headline, intro, cta } = projectsPageContent;
const projectImageMap = {
	'axiom-zurich': axiomzurichImg,
	'advancedaps': advancedapsImg,
	'elimu-international': elimunowwImg,
	'ney-neys-kitchen': neyneyskitchenImg,
	'jason-garage-doors': mwsGarageDoorImg,
} as const;

const allTags = Array.from(new Set(projectsData.flatMap((p) => p.tags ?? []))).sort();
---

<Layout
	title={meta.title}
	description={meta.description}
	canonicalURL="/projects"
	keywords="web development portfolio, website projects, custom website examples, web design case studies, British Columbia web development"
>
	<section class="relative bg-bg overflow-hidden">
		<div class="projects-dot-bg" aria-hidden="true"></div>

		<div class="relative pt-28 sm:pt-32 md:pt-36 pb-20 sm:pb-24 md:pb-32 px-4 sm:px-6 lg:px-8">
			<div class="max-w-6xl mx-auto">
				<!-- Header Section (unchanged) -->
				<header class="mb-12 sm:mb-16 md:mb-20">
					<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-10 items-end">
						<div class="lg:col-span-7">
							<h1 class="font-headline font-semibold text-text leading-[0.9] tracking-[-0.04em] text-[clamp(4rem,12vw,7.5rem)]">
								{headline}
							</h1>
						</div>
						<div class="lg:col-span-5 lg:pb-3">
							<p class="text-sm sm:text-base md:text-lg text-textMuted leading-relaxed max-w-prose">
								{intro}
							</p>
						</div>
					</div>
				</header>

				<!-- Filter by tag (optional, improves browsing) -->
				{allTags.length > 0 && (
					<div class="mb-8 flex flex-wrap items-center gap-2">
						<span class="text-sm font-medium text-textMuted mr-1">Filter:</span>
						<a
							href="/projects"
							class="projects-filter-tag inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium bg-text text-bg transition-colors hover:opacity-90"
							data-tag=""
						>
							All
						</a>
						{allTags.map((tag) => {
							const slug = tag.toLowerCase().replace(/\s+/g, '-');
							return (
								<a
									href={`/projects?tag=${encodeURIComponent(slug)}`}
									class="projects-filter-tag inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium bg-black/8 text-text hover:bg-black/12 transition-colors"
									data-tag={slug}
								>
									{tag}
								</a>
							);
						})}
					</div>
				)}

				<!-- Projects grid -->
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8" id="projects-grid">
					{projectsData.map((project, index) => {
						const img = projectImageMap[project.id];
						const tags = project.tags ?? [];
						const tagSlugs = tags.map((t) => t.toLowerCase().replace(/\s+/g, '-'));
						const viewUrl = project.viewUrl ?? '#';
						const isExternal = viewUrl.startsWith('http');
						return (
							<article
								class="project-card group"
								data-tags={tagSlugs.join(' ')}
							>
								<a
									href={viewUrl}
									target={isExternal ? '_blank' : undefined}
									rel={isExternal ? 'noopener noreferrer' : undefined}
									class="block h-full rounded-2xl bg-white border border-black/5 shadow-[0_1px_0_rgba(0,0,0,0.04)] hover:shadow-[0_20px_40px_-12px_rgba(0,0,0,0.12)] hover:border-black/8 transition-all duration-300 overflow-hidden focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
									aria-label={`View ${project.title}`}
								>
									{img ? (
										<div class="aspect-video overflow-hidden bg-black/[0.03]">
											<AstroImage
												src={img}
												alt={`${project.title} — project preview`}
												width={800}
												height={450}
												class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]"
												loading={index < 4 ? 'eager' : 'lazy'}
												fetchpriority={index < 4 ? 'high' : 'low'}
											/>
										</div>
									) : (
										<div class="aspect-video bg-black/5 flex items-center justify-center">
											<span class="text-textMuted text-sm font-medium">Preview</span>
										</div>
									)}
									<div class="p-5 sm:p-6">
										<h2 class="font-headline text-lg sm:text-xl font-semibold text-text mb-2 group-hover:text-accent transition-colors">
											{project.title}
										</h2>
										{project.summary ? (
											<p class="text-sm text-textMuted leading-relaxed line-clamp-3 mb-3">
												{project.summary}
											</p>
										) : null}
										{tags.length > 0 ? (
											<ul class="flex flex-wrap gap-2 mb-4" aria-label="Project tags">
												{tags.map((tag) => (
													<li class="inline-flex items-center px-2.5 py-1 rounded-full bg-black/5 text-text text-xs font-medium">
														{tag}
													</li>
												))}
											</ul>
										) : null}
										<span class="inline-flex items-center gap-2 text-sm font-medium text-accent group-hover:gap-3 transition-all">
											View site
											<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
											</svg>
										</span>
									</div>
								</a>
							</article>
						);
					})}
				</div>

				<!-- CTA block (unchanged) -->
				<div class="mt-16 sm:mt-20 text-center">
					<p class="text-sm text-textMuted mb-6">{cta.line}</p>
					<a
						href={cta.href}
						class="group inline-flex items-center gap-3 px-8 py-4 bg-text text-bg font-medium rounded-full text-sm hover:scale-[1.02] transition-all duration-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
					>
						<span>{cta.buttonText}</span>
						<svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</a>
				</div>
			</div>
		</div>
	</section>

	<Footer />
</Layout>

<script>
	// Optional: client-side filter by ?tag= when JS runs (keeps All / tag links working via URL)
	function initTagFilter() {
		const params = new URLSearchParams(typeof window !== 'undefined' ? window.location.search : '');
		const tag = params.get('tag')?.toLowerCase();
		const cards = document.querySelectorAll('.project-card');
		const filterLinks = document.querySelectorAll('.projects-filter-tag');

		function filterByTag(selectedTag: string) {
			cards.forEach((card) => {
				const tags = (card.getAttribute('data-tags') ?? '').split(/\s+/).filter(Boolean);
				const show = !selectedTag || tags.includes(selectedTag);
				(card as HTMLElement).style.display = show ? '' : 'none';
			});
			filterLinks.forEach((link) => {
				const linkTag = (link.getAttribute('data-tag') ?? '').toLowerCase().replace(/\s+/g, '-');
				const isActive = (selectedTag && linkTag === selectedTag) || (!selectedTag && !linkTag);
				link.classList.toggle('bg-text', isActive && !linkTag);
				link.classList.toggle('text-bg', isActive && !linkTag);
				link.classList.toggle('bg-black/8', !isActive || !!linkTag);
				link.classList.toggle('text-text', !isActive || !!linkTag);
			});
		}

		filterByTag(tag ?? '');
	}

	if (typeof document !== 'undefined') {
		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', initTagFilter);
		} else {
			initTagFilter();
		}
	}
</script>

<style>
	.projects-dot-bg {
		position: absolute;
		inset: 0;
		background-image: radial-gradient(circle, rgba(0, 0, 0, 0.10) 1px, transparent 1px);
		background-size: 24px 24px;
		opacity: 0.18;
		pointer-events: none;
		mask-image: radial-gradient(ellipse at 50% 10%, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0) 62%);
	}
</style>
