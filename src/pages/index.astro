---
import Layout from '../layouts/Layout.astro';
import RecentProjects from '../components/RecentProjects.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Testimonials from '../components/Testimonials.astro';
import PricingInteractive from '../components/PricingInteractive';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import Hero2 from '@/components/Hero2.astro';
import ProblemStatement from '@/components/ProblemStatement.astro';
import WhyChooseUs from '@/components/WhyChooseUs.astro';
import Services from '@/components/Services.astro';
import AfterLaunch from '@/components/AfterLaunch.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';
import ReviewSchema from '../components/ReviewSchema.astro';
import heroBackground from '@/assets/images/hero/hero-background.avif';
---

<Layout
	title="Bluebird - Custom Websites & Local SEO services"
	description="We build custom websites that load fast, rank well, and convert visitors into customers. Serving businesses across BC, Canada & beyond."
	canonicalURL="/"
	structuredDataType="WebSite"
	keywords="web development BC, website design Vancouver, marketing services, custom websites Canada, web design Surrey, brand design British Columbia, conversion optimization, fast websites, SEO services, web design studio Vancouver"
	heroImagePreloadUrl={typeof heroBackground === 'string' ? heroBackground : heroBackground.src}
>
	<Hero2 />
	<ProblemStatement />
	<WhyChooseUs />
	<Services />
	<RecentProjects />
	<HowItWorks />
	<AfterLaunch />
	<Testimonials />
	<PricingInteractive client:visible />
	<FAQ />
	<CTA id="contact" />
	<Footer />
	<LocalBusinessSchema />
	<ReviewSchema />
</Layout>
