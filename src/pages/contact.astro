---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/CTA.astro';
---

<Layout
	title="Contact – Get in Touch | Bluebird"
	description="Get in touch with Bluebird. We build custom websites and web applications for businesses across BC. Email hello@bluebirdweb.ca or call (236) 863-5191."
	canonicalURL="/contact"
>
	<!-- Reuse the main CTA/contact section so this page matches the updated design -->
	<div class="pt-20 sm:pt-24">
		<h1 class="sr-only">Contact</h1>
		<CTA id="contact-page" />
	</div>

	<Footer />
</Layout>
